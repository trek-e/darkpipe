# DarkPipe Caddy Reverse Proxy
# Forwards webmail and groupware traffic from public internet to home device over WireGuard tunnel

# Webmail subdomain (e.g., mail.example.com, mail.example.org)
{$WEBMAIL_DOMAINS} {
	# CalDAV/CardDAV auto-discovery (RFC 6764)
	redir /.well-known/caldav /radicale/ 301
	redir /.well-known/carddav /radicale/ 301

	# For Stalwart (built-in CalDAV/CardDAV), use these instead:
	# redir /.well-known/caldav / 301
	# redir /.well-known/carddav / 301
	# (and remove the handle_path /radicale/* block)

	# CalDAV/CardDAV reverse proxy to home device Radicale
	# Note: Remove this block when using Stalwart (built-in CalDAV/CardDAV on port 8080)
	handle_path /radicale/* {
		reverse_proxy 10.0.0.2:5232 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Mozilla Thunderbird autoconfig (well-known path)
	handle /.well-known/autoconfig/mail/config-v1.1.xml {
		reverse_proxy 10.0.0.2:8090
	}

	# Microsoft Outlook autodiscover
	handle /autodiscover/autodiscover.xml {
		reverse_proxy 10.0.0.2:8090
	}

	# Profile download (QR code token redemption)
	handle /profile/* {
		reverse_proxy 10.0.0.2:8090
	}

	# QR code generation (authenticated, for webmail iframe)
	handle /qr/* {
		reverse_proxy 10.0.0.2:8090
	}

	# Webmail reverse proxy (default route)
	reverse_proxy 10.0.0.2:8080 {
		# Forward client headers
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# WebSocket support (for real-time updates)
		header_up Connection {>Connection}
		header_up Upgrade {>Upgrade}
	}

	# JSON access logging
	log {
		output file /var/log/caddy/access.log
		format json
	}

	# Health check endpoint (optional monitoring)
	handle /health {
		respond "OK" 200
	}
}

# Autoconfig subdomain for Thunderbird (autoconfig.example.com)
{$AUTOCONFIG_DOMAINS:autoconfig.{$RELAY_DOMAIN:example.com}} {
	handle /mail/config-v1.1.xml {
		reverse_proxy 10.0.0.2:8090
	}
	handle {
		respond "DarkPipe Autoconfig" 200
	}
}

# Autodiscover subdomain for Outlook (autodiscover.example.com)
{$AUTODISCOVER_DOMAINS:autodiscover.{$RELAY_DOMAIN:example.com}} {
	handle /autodiscover/autodiscover.xml {
		reverse_proxy 10.0.0.2:8090
	}
	handle {
		respond "DarkPipe Autodiscover" 200
	}
}

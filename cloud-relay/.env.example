# =============================================================================
# DarkPipe Cloud Relay — Environment Variables
# =============================================================================
# Copy this file to .env and customize for your deployment.
# Source: cloud-relay/relay/config/config.go, cloud-relay/docker-compose.yml
#
# Legend:
#   # Required          — must be set for the relay to function
#   # Required (mtls)   — required only when RELAY_TRANSPORT=mtls
#   # Required (overflow) — required only when RELAY_OVERFLOW_ENABLED=true
#   # Optional           — has a sensible default; override as needed

# -----------------------------------------------------------------------------
# Relay Core
# Source: config.go, docker-compose.yml
# -----------------------------------------------------------------------------

# Required — public-facing hostname for the relay MTA
RELAY_HOSTNAME=relay.example.com

# Required — primary mail domain
RELAY_DOMAIN=example.com

# Optional — address:port the Go relay daemon listens on
RELAY_LISTEN_ADDR=127.0.0.1:10025

# Optional — transport to the home device: "wireguard" or "mtls"
RELAY_TRANSPORT=wireguard

# Required — home device SMTP endpoint (over WireGuard or mTLS)
RELAY_HOME_ADDR=10.8.0.2:25

# Required — home device IP on the WireGuard tunnel interface.
# Must match the WireGuard Address assigned to the home device (typically 10.8.0.2).
# Used by the Caddyfile to proxy traffic and by the validation script for checks.
HOME_DEVICE_IP=10.8.0.2

# Optional — max inbound message size in bytes (default: 50 MiB)
RELAY_MAX_MESSAGE_BYTES=52428800

# Optional — enable debug logging (logs full email addresses instead of redacted)
RELAY_DEBUG=false

# Optional — ephemeral storage verification interval in seconds
RELAY_EPHEMERAL_CHECK_INTERVAL=60

# -----------------------------------------------------------------------------
# mTLS Transport
# Source: config.go
# Required only when RELAY_TRANSPORT=mtls
# -----------------------------------------------------------------------------

# Required (mtls) — path to CA certificate
# RELAY_CA_CERT=/certs/ca.crt

# Required (mtls) — path to client certificate
# RELAY_CLIENT_CERT=/certs/client.crt

# Required (mtls) — path to client private key
# RELAY_CLIENT_KEY=/certs/client.key

# -----------------------------------------------------------------------------
# TLS Monitoring & Notifications
# Source: config.go
# -----------------------------------------------------------------------------

# Optional — enable strict TLS mode
RELAY_STRICT_MODE=false

# Optional — webhook URL for TLS monitoring alerts
# RELAY_WEBHOOK_URL=https://webhook.example.com/darkpipe

# Optional — email for Let's Encrypt certificate automation
# CERTBOT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Queue (offline message buffering)
# Source: config.go
# -----------------------------------------------------------------------------

# Optional — enable message queuing when home device is offline (default: true)
RELAY_QUEUE_ENABLED=true

# Optional — path to age identity file for queue encryption
RELAY_QUEUE_KEY_PATH=/data/queue-keys/identity

# Optional — max RAM for in-memory queue in bytes (default: 200 MiB)
RELAY_QUEUE_MAX_RAM=209715200

# Optional — max number of messages in queue (default: 10000)
RELAY_QUEUE_MAX_MESSAGES=10000

# Optional — max message age in hours before purge (default: 168 = 7 days)
RELAY_QUEUE_TTL_HOURS=168

# Optional — path for queue metadata snapshots
RELAY_QUEUE_SNAPSHOT_PATH=/data/queue-state/snapshot.json

# -----------------------------------------------------------------------------
# S3 Overflow (spill queue to object storage when RAM is full)
# Source: config.go
# -----------------------------------------------------------------------------

# Optional — enable S3 overflow (requires credentials below)
RELAY_OVERFLOW_ENABLED=false

# Required (overflow) — S3-compatible endpoint
# RELAY_OVERFLOW_ENDPOINT=gateway.storjshare.io

# Optional — bucket name for overflow storage
RELAY_OVERFLOW_BUCKET=darkpipe-queue

# Required (overflow) — S3 access key
# RELAY_OVERFLOW_ACCESS_KEY=

# Required (overflow) — S3 secret key
# RELAY_OVERFLOW_SECRET_KEY=

# Optional — use SSL for S3 connections (default: true)
RELAY_OVERFLOW_USE_SSL=true

# -----------------------------------------------------------------------------
# Caddy Reverse Proxy
# Source: docker-compose.yml
# Caddy uses RELAY_DOMAIN above to construct these; override if needed.
# -----------------------------------------------------------------------------

# Optional — webmail domain (default: mail.${RELAY_DOMAIN})
# WEBMAIL_DOMAINS=mail.example.com

# Optional — autoconfig domain for Thunderbird (default: autoconfig.${RELAY_DOMAIN})
# AUTOCONFIG_DOMAINS=autoconfig.example.com

# Optional — autodiscover domain for Outlook (default: autodiscover.${RELAY_DOMAIN})
# AUTODISCOVER_DOMAINS=autodiscover.example.com

---
const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/quickstart', label: 'Quickstart' },
  { href: '/faq', label: 'FAQ' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-40 border-b border-slate-mid/50 bg-void/80 backdrop-blur-xl" role="banner">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5" aria-label="DarkPipe home">
      <div class="relative flex h-8 w-8 items-center justify-center">
        <div class="absolute inset-0 rounded-md bg-pipe/10 transition-colors group-hover:bg-pipe/20"></div>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4h3v12H4V4zm9 0h3v12h-3V4z" fill="currentColor" class="text-pipe" />
          <path d="M7 8h6v4H7V8z" fill="currentColor" class="text-pipe-bright opacity-60" />
        </svg>
      </div>
      <span class="font-display text-lg font-bold tracking-tight text-snow">
        dark<span class="text-pipe">pipe</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'rounded-md px-3.5 py-2 text-sm font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'bg-slate-mid/60 text-pipe'
                : 'text-mist hover:bg-slate-mid/40 hover:text-snow',
            ]}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="ml-3">
        <a
          href="https://github.com/trek-e/darkpipe"
          class="inline-flex items-center gap-2 rounded-md bg-slate-mid/50 px-3.5 py-2 text-sm font-medium text-mist transition-colors hover:bg-slate-mid hover:text-snow"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-md text-mist transition-colors hover:bg-slate-mid/40 hover:text-snow md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Toggle navigation menu"
      id="mobile-menu-btn"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="menu-icon">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
      </svg>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="close-icon hidden">
        <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav panel -->
  <div id="mobile-nav" class="hidden border-t border-slate-mid/50 bg-abyss/95 backdrop-blur-xl md:hidden" role="region" aria-label="Mobile navigation">
    <ul class="flex flex-col gap-1 px-6 py-4" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block rounded-md px-3 py-2.5 text-sm font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'bg-slate-mid/60 text-pipe'
                : 'text-mist hover:bg-slate-mid/40 hover:text-snow',
            ]}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2 border-t border-slate-mid/30 pt-3">
        <a
          href="https://github.com/trek-e/darkpipe"
          class="inline-flex items-center gap-2 rounded-md px-3 py-2.5 text-sm font-medium text-mist transition-colors hover:text-snow"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const menuIcon = btn?.querySelector('.menu-icon');
  const closeIcon = btn?.querySelector('.close-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
